{
  "name": "@nfq/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare:solution-routes": "node ./scripts/generate-solution-routes.mjs",
    "predev": "npm run prepare:solution-routes",
    "dev": "next dev --port 3200",
    "predev:turbo": "npm run prepare:solution-routes",
    "dev:turbo": "next dev --turbopack --port 3200",
    "predev:e2e": "node ./scripts/assert-supported-node.mjs && npm run prepare:solution-routes",
    "dev:e2e": "sh -c 'next dev --hostname localhost --port ${NEXT_E2E_PORT:-3200}'",
    "prebuild": "npm run prepare:solution-routes",
    "build": "next build",
    "postbuild": "node ./scripts/assert-solution-artifacts.mjs",
    "prebuild:e2e": "node ./scripts/assert-supported-node.mjs && npm run prepare:solution-routes",
    "build:e2e": "next build",
    "postbuild:e2e": "node ./scripts/assert-solution-artifacts.mjs",
    "prestart": "node ./scripts/assert-solution-artifacts.mjs",
    "start": "next start --port 3200",
    "prestart:e2e": "node ./scripts/assert-supported-node.mjs && node ./scripts/assert-solution-artifacts.mjs",
    "start:e2e": "sh -c 'next start --hostname localhost --port ${NEXT_E2E_PORT:-3200}'",
    "prelint": "npm run prepare:solution-routes",
    "lint": "next lint",
    "precheck-types": "rm -rf .next && npm run prepare:solution-routes",
    "check-types": "tsc --noEmit",
    "pretest": "npm run prepare:solution-routes",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright:test": "playwright test",
    "playwright:report": "playwright show-report"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.2",
    "@grove/ui": "file:../packages/ui",
    "@grove/web-shared": "file:../packages/web-shared",
    "@solution/appointment-booking-ui": "file:../solutions/appointment_booking/ui",
    "@solution/driver-verification-ui": "file:../solutions/driver_verification/ui",
    "@uiw/react-codemirror": "^4.25.8",
    "@xyflow/react": "^12.10.2",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "geist": "^1.7.0",
    "livekit-client": "2.17.2",
    "next": "^15",
    "react": "^19",
    "react-dom": "^19",
    "react-window": "^2.2.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.0.0",
    "wavesurfer.js": "^7.12.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5.7",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0"
  }
}
