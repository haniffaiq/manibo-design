        <mxCell id="eu_shield" value="GDPR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a3c5e;strokeColor=none;fontColor=#ffffff;fontSize=9;fontStyle=1;fontFamily=Helvetica;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="1095" y="126" width="48" height="18" as="geometry" />
        </mxCell>

        <!-- ==================== CDN ==================== -->
        <mxCell id="cdn" value="&lt;b style=&quot;font-size:13px&quot;&gt;CDN (CloudFlare)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#4a6d8c&quot;&gt;Global edge caching, DDoS protection&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=10;fontFamily=Helvetica;fontColor=#1a3c5e;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="65" width="1040" height="45" as="geometry" />
        </mxCell>

        <!-- Arrow CDN → LB -->
        <mxCell id="dep_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeColor=#6c8ebf;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="cdn" target="lb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dep_a1_label" value="HTTPS" style="edgeLabel;html=1;fontSize=9;fontStyle=1;fontFamily=Helvetica;fontColor=#6c8ebf;align=center;verticalAlign=middle;" vertex="1" connectable="0" parent="dep_a1">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- ==================== LOAD BALANCER ==================== -->
        <mxCell id="lb" value="&lt;b style=&quot;font-size:13px&quot;&gt;Load Balancer (HTTPS)&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px;color:#4a6d8c&quot;&gt;TLS termination, health checks, rate limiting&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;arcSize=10;fontFamily=Helvetica;fontColor=#1a3c5e;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="260" y="155" width="680" height="45" as="geometry" />
        </mxCell>

        <!-- ==================== SERVICE TIER (3 services) ==================== -->

        <!-- Arrow LB → Frontend -->
        <mxCell id="dep_a2a" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jetSize=auto;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="lb" target="svc_frontend">
          <mxGeometry relative="1" as="geometry" />
