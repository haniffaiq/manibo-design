        <mxCell id="p4_subtitle" value="Cloud-native, EU-hosted, GDPR-compliant deployment" style="text;html=1;fontSize=12;fontStyle=0;align=center;verticalAlign=middle;whiteSpace=wrap;fontFamily=Helvetica;fontColor=#6b7b8d;" vertex="1" parent="1">
