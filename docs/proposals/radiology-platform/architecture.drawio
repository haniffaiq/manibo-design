        <mxCell id="eu_region" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1a3c5e;strokeWidth=2;arcSize=4;dashed=1;dashPattern=12 4;" vertex="1" parent="1">
